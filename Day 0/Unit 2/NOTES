//-----------------------------------------ARRAYLISTS---------------------------------------------

// CREATE
ArrayList<Integer> nums = new ArrayList<>();
ArrayList<String> words = new ArrayList<>();

// ADD / GET / SET / REMOVE
nums.add(5);                 // add to end
nums.add(0, 99);             // add at index (shifts right)
int x = nums.get(0);         // read
nums.set(0, 7);              // replace
nums.remove(0);              // remove by INDEX (shifts left)
nums.remove(Integer.valueOf(5)); // remove by VALUE (for Integer lists)

// SIZE
int n = nums.size();

// PRINT (calls toString on list)
System.out.println(nums);

// IMPORTANT: remove while looping
// If removing while scanning LEFT->RIGHT, do i-- after remove.
for (int i = 0; i < words.size(); i++) {
    if (words.get(i).startsWith("p")) {
        words.remove(i);
        i--; // don’t skip the next item
    }
}
// Alternative: loop RIGHT->LEFT so you don’t need i--
for (int i = words.size() - 1; i >= 0; i--) {
    if (words.get(i).startsWith("p")) {
        words.remove(i);
    }
}

// FOR-EACH (read only; don’t remove from list here)
for (String s : words) {
    // ok to read/compute
}


