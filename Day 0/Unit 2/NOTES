//-----------------------------------------CLASSIC TEST PATTERNS----------------------------------

// 1) Stable partition (evens before odds, preserve order)
public static int[] moveEvenBeforeOdd(int[] nums) {
    int[] res = new int[nums.length];
    int evenCount = 0;
    for (int x : nums) if (x % 2 == 0) evenCount++;

    int ei = 0, oi = evenCount;
    for (int x : nums) {
        if (x % 2 == 0) res[ei++] = x;
        else res[oi++] = x;
    }
    return res;
}

// 2) Filter+transform (square + 10, exclude endings 5 or 6)
public static ArrayList<Integer> square56(ArrayList<Integer> nums) {
    if (nums == null) throw new IllegalArgumentException();
    ArrayList<Integer> res = new ArrayList<>();
    for (int n : nums) {
        int v = n*n + 10;
        int last = Math.abs(v) % 10;
        if (last != 5 && last != 6) res.add(v);
    }
    return res;
}

// 3) noYY (keep original strings if (s+"y") does NOT contain "yy")
public static ArrayList<String> noYY(ArrayList<String> strs) {
    if (strs == null) throw new IllegalArgumentException();
    ArrayList<String> res = new ArrayList<>();
    for (String s : strs) {
        if (!(s + "y").contains("yy")) res.add(s);
    }
    return res;
}

// 4) Rotate array left by 1 (first goes last)
public static void firstComesLast(String[] arr) {
    if (arr == null || arr.length <= 1) return;
    String first = arr[0];
    for (int i = 0; i < arr.length - 1; i++) arr[i] = arr[i+1];
    arr[arr.length - 1] = first;
}

// 5) Rotate array right by 1 (last goes first)
public static void lastComesFirst(String[] arr) {
    if (arr == null || arr.length <= 1) return;
    String last = arr[arr.length - 1];
    for (int i = arr.length - 1; i >= 1; i--) arr[i] = arr[i-1];
    arr[0] = last;
}

