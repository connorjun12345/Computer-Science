// toString for 2D (each row newline, trailing space after each number)
public String toString2D(double[][] a) {
    String out = "";
    for (int r = 0; r < a.length; r++) {
        for (int c = 0; c < a[r].length; c++) {
            out += a[r][c] + " ";
        }
        if (r < a.length - 1) out += "\n";
    }
    return out;
}


//-----------------------------------------2D ARRAYLIST (ArrayList<ArrayList<T>>)-----------------

ArrayList<ArrayList<String>> classes = new ArrayList<>();

// Add a row
classes.add(new ArrayList<>());

// Add to row
classes.get(0).add("Math");

// Loop
for (int i = 0; i < classes.size(); i++) {
    for (int j = 0; j < classes.get(i).size(); j++) {
        String val = classes.get(i).get(j);
    }
}

// Safe remove in 2D ArrayList (right-to-left on inner list)
for (int i = 0; i < classes.size(); i++) {
    for (int j = classes.get(i).size() - 1; j >= 0; j--) {
        if (classes.get(i).get(j).equals("drop")) {
            classes.get(i).remove(j);
        }
    }
}


